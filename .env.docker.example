# EDL Microfinance — Docker environment template
# Copy to .env.docker and fill in values before running:
#   docker-compose --env-file .env.docker up --build

# Generate with: php artisan key:generate --show
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate

DB_PASSWORD=edl_secure_password_2025

# From contracts/deployments/ganache-latest.json after running deploy-all.js
IDENTITY_REGISTRY_ADDRESS=0x
EDL_ACCESS_CONTROL_ADDRESS=0x
LOAN_FACTORY_ADDRESS=0x

# Ganache account[0] — deployer and owner of all EDL contracts
# Standard Hardhat mnemonic "test test...junk", path m/44'/60'/0'/0/0
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
